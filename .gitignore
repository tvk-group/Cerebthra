# .gitignore

```gitignore
# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/

# Environment variables
.env
.env.local
.env.production
.env.development

# Vercel
.vercel/

# Build folders
dist/
build/
out/

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Temporary files
*.tmp
*.temp

# Cache
.cache/

# Coverage
coverage/
```

